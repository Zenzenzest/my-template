{
  "name": "front-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preview-release": "release-it --dry-run",
    "dev-release": "release-it --no-git.push && git push origin dev --follow-tags",
    "promote-release": "git checkout main && git merge dev && git push origin main && git checkout dev",
    "start": "npm run dev",
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "release-it"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "release-it": "^20.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-react-meta-map": "^1.0.9"
  }
}
